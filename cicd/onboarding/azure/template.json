{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_description": "StackQL audit — OIDC bootstrap for Azure (subscription-scope). Creates TWO User Assigned Managed Identities: 'audit' (read-only, federated for main + pull_request subjects) and 'mutate' (read+write, federated for main only). Role assignments at subscription scope. No client secrets."
  },
  "parameters": {
    "repoFullName": {
      "type": "string",
      "metadata": { "description": "GitHub repo allowed to assume these identities (owner/repo)." }
    },
    "auditIdentityName": {
      "type": "string",
      "defaultValue": "stackql-audit",
      "metadata": { "description": "Name of the audit (read-only) UAMI." }
    },
    "mutateIdentityName": {
      "type": "string",
      "defaultValue": "stackql-mutate",
      "metadata": { "description": "Name of the mutate (read+write, main-branch only) UAMI." }
    },
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "stackql-audit-rg",
      "metadata": { "description": "Resource group to create/use for the UAMIs." }
    },
    "location": {
      "type": "string",
      "defaultValue": "eastus",
      "metadata": { "description": "Region for the resource group + UAMIs." }
    }
  },
  "variables": {
    "readerRoleId":             "acdd72a7-3385-48ef-bd42-f606fba81ae7",
    "securityReaderRoleId":     "39bc4728-0917-49c7-9d2c-d95423bc2eb4",
    "vmContributorRoleId":      "9980e02c-c2be-4d73-94e8-173b1dc7cf3c",
    "networkContributorRoleId": "4d97b98b-1d4f-4787-a291-c67834d212e7"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2022-09-01",
      "name": "[parameters('resourceGroupName')]",
      "location": "[parameters('location')]",
      "properties": {}
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "uami-deployment",
      "resourceGroup": "[parameters('resourceGroupName')]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/resourceGroups', parameters('resourceGroupName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": { "scope": "inner" },
        "parameters": {
          "auditIdentityName":  { "value": "[parameters('auditIdentityName')]" },
          "mutateIdentityName": { "value": "[parameters('mutateIdentityName')]" },
          "location":           { "value": "[parameters('location')]" },
          "repoFullName":       { "value": "[parameters('repoFullName')]" }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "auditIdentityName":  { "type": "string" },
            "mutateIdentityName": { "type": "string" },
            "location":           { "type": "string" },
            "repoFullName":       { "type": "string" }
          },
          "resources": [
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
              "apiVersion": "2023-01-31",
              "name": "[parameters('auditIdentityName')]",
              "location": "[parameters('location')]"
            },
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
              "apiVersion": "2023-01-31",
              "name": "[format('{0}/main', parameters('auditIdentityName'))]",
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('auditIdentityName'))]"
              ],
              "properties": {
                "issuer":    "https://token.actions.githubusercontent.com",
                "subject":   "[format('repo:{0}:ref:refs/heads/main', parameters('repoFullName'))]",
                "audiences": [ "api://AzureADTokenExchange" ]
              }
            },
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
              "apiVersion": "2023-01-31",
              "name": "[format('{0}/pull-request', parameters('auditIdentityName'))]",
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('auditIdentityName'))]",
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials', parameters('auditIdentityName'), 'main')]"
              ],
              "properties": {
                "issuer":    "https://token.actions.githubusercontent.com",
                "subject":   "[format('repo:{0}:pull_request', parameters('repoFullName'))]",
                "audiences": [ "api://AzureADTokenExchange" ]
              }
            },
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
              "apiVersion": "2023-01-31",
              "name": "[parameters('mutateIdentityName')]",
              "location": "[parameters('location')]"
            },
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
              "apiVersion": "2023-01-31",
              "name": "[format('{0}/main', parameters('mutateIdentityName'))]",
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('mutateIdentityName'))]"
              ],
              "properties": {
                "issuer":    "https://token.actions.githubusercontent.com",
                "subject":   "[format('repo:{0}:ref:refs/heads/main', parameters('repoFullName'))]",
                "audiences": [ "api://AzureADTokenExchange" ]
              }
            }
          ],
          "outputs": {
            "auditPrincipalId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('auditIdentityName')), '2023-01-31').principalId]"
            },
            "auditClientId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('auditIdentityName')), '2023-01-31').clientId]"
            },
            "mutatePrincipalId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('mutateIdentityName')), '2023-01-31').principalId]"
            },
            "mutateClientId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('mutateIdentityName')), '2023-01-31').clientId]"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, parameters('auditIdentityName'), 'reader')]",
      "dependsOn": [ "uami-deployment" ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('readerRoleId'))]",
        "principalId":      "[reference('uami-deployment').outputs.auditPrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, parameters('auditIdentityName'), 'security-reader')]",
      "dependsOn": [ "uami-deployment" ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('securityReaderRoleId'))]",
        "principalId":      "[reference('uami-deployment').outputs.auditPrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, parameters('mutateIdentityName'), 'reader')]",
      "dependsOn": [ "uami-deployment" ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('readerRoleId'))]",
        "principalId":      "[reference('uami-deployment').outputs.mutatePrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, parameters('mutateIdentityName'), 'security-reader')]",
      "dependsOn": [ "uami-deployment" ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('securityReaderRoleId'))]",
        "principalId":      "[reference('uami-deployment').outputs.mutatePrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, parameters('mutateIdentityName'), 'vm-contributor')]",
      "dependsOn": [ "uami-deployment" ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('vmContributorRoleId'))]",
        "principalId":      "[reference('uami-deployment').outputs.mutatePrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, parameters('mutateIdentityName'), 'network-contributor')]",
      "dependsOn": [ "uami-deployment" ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('networkContributorRoleId'))]",
        "principalId":      "[reference('uami-deployment').outputs.mutatePrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "tenantId": {
      "type": "string",
      "value": "[subscription().tenantId]"
    },
    "subscriptionId": {
      "type": "string",
      "value": "[subscription().subscriptionId]"
    },
    "clientId": {
      "type": "string",
      "value": "[reference('uami-deployment').outputs.auditClientId.value]"
    },
    "mutateClientId": {
      "type": "string",
      "value": "[reference('uami-deployment').outputs.mutateClientId.value]"
    }
  }
}
