{
  "$schema": "https://schema.management.azure.com/schemas/2019-08-01/managementGroupDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_description": "StackQL audit — OIDC bootstrap for Azure at management-group scope. Creates two User Assigned Managed Identities in a host subscription, and assigns Reader/Security Reader (audit) and Reader/Security Reader/VM Contributor/Network Contributor (mutate) at the management group scope so the audit covers every subscription under the MG. Mutate identity's federated credential is locked to main-branch context."
  },
  "parameters": {
    "repoFullName": {
      "type": "string",
      "metadata": { "description": "GitHub repo allowed to assume these identities (owner/repo)." }
    },
    "hostSubscriptionId": {
      "type": "string",
      "metadata": { "description": "Subscription ID that hosts the UAMIs (any sub under the management group; identity itself is global)." }
    },
    "auditIdentityName": {
      "type": "string",
      "defaultValue": "stackql-audit"
    },
    "mutateIdentityName": {
      "type": "string",
      "defaultValue": "stackql-mutate"
    },
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "stackql-audit-rg"
    },
    "location": {
      "type": "string",
      "defaultValue": "eastus"
    }
  },
  "variables": {
    "readerRoleId":             "acdd72a7-3385-48ef-bd42-f606fba81ae7",
    "securityReaderRoleId":     "39bc4728-0917-49c7-9d2c-d95423bc2eb4",
    "vmContributorRoleId":      "9980e02c-c2be-4d73-94e8-173b1dc7cf3c",
    "networkContributorRoleId": "4d97b98b-1d4f-4787-a291-c67834d212e7"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "uami-subscription-deployment",
      "subscriptionId": "[parameters('hostSubscriptionId')]",
      "location": "[parameters('location')]",
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": { "scope": "inner" },
        "parameters": {
          "auditIdentityName":  { "value": "[parameters('auditIdentityName')]" },
          "mutateIdentityName": { "value": "[parameters('mutateIdentityName')]" },
          "resourceGroupName":  { "value": "[parameters('resourceGroupName')]" },
          "location":           { "value": "[parameters('location')]" },
          "repoFullName":       { "value": "[parameters('repoFullName')]" }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "auditIdentityName":  { "type": "string" },
            "mutateIdentityName": { "type": "string" },
            "resourceGroupName":  { "type": "string" },
            "location":           { "type": "string" },
            "repoFullName":       { "type": "string" }
          },
          "resources": [
            {
              "type": "Microsoft.Resources/resourceGroups",
              "apiVersion": "2022-09-01",
              "name": "[parameters('resourceGroupName')]",
              "location": "[parameters('location')]",
              "properties": {}
            },
            {
              "type": "Microsoft.Resources/deployments",
              "apiVersion": "2022-09-01",
              "name": "uami-rg-deployment",
              "resourceGroup": "[parameters('resourceGroupName')]",
              "dependsOn": [
                "[resourceId('Microsoft.Resources/resourceGroups', parameters('resourceGroupName'))]"
              ],
              "properties": {
                "mode": "Incremental",
                "expressionEvaluationOptions": { "scope": "inner" },
                "parameters": {
                  "auditIdentityName":  { "value": "[parameters('auditIdentityName')]" },
                  "mutateIdentityName": { "value": "[parameters('mutateIdentityName')]" },
                  "location":           { "value": "[parameters('location')]" },
                  "repoFullName":       { "value": "[parameters('repoFullName')]" }
                },
                "template": {
                  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                  "contentVersion": "1.0.0.0",
                  "parameters": {
                    "auditIdentityName":  { "type": "string" },
                    "mutateIdentityName": { "type": "string" },
                    "location":           { "type": "string" },
                    "repoFullName":       { "type": "string" }
                  },
                  "resources": [
                    {
                      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
                      "apiVersion": "2023-01-31",
                      "name": "[parameters('auditIdentityName')]",
                      "location": "[parameters('location')]"
                    },
                    {
                      "type": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
                      "apiVersion": "2023-01-31",
                      "name": "[format('{0}/main', parameters('auditIdentityName'))]",
                      "dependsOn": [
                        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('auditIdentityName'))]"
                      ],
                      "properties": {
                        "issuer":    "https://token.actions.githubusercontent.com",
                        "subject":   "[format('repo:{0}:ref:refs/heads/main', parameters('repoFullName'))]",
                        "audiences": [ "api://AzureADTokenExchange" ]
                      }
                    },
                    {
                      "type": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
                      "apiVersion": "2023-01-31",
                      "name": "[format('{0}/pull-request', parameters('auditIdentityName'))]",
                      "dependsOn": [
                        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('auditIdentityName'))]",
                        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials', parameters('auditIdentityName'), 'main')]"
                      ],
                      "properties": {
                        "issuer":    "https://token.actions.githubusercontent.com",
                        "subject":   "[format('repo:{0}:pull_request', parameters('repoFullName'))]",
                        "audiences": [ "api://AzureADTokenExchange" ]
                      }
                    },
                    {
                      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
                      "apiVersion": "2023-01-31",
                      "name": "[parameters('mutateIdentityName')]",
                      "location": "[parameters('location')]"
                    },
                    {
                      "type": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
                      "apiVersion": "2023-01-31",
                      "name": "[format('{0}/main', parameters('mutateIdentityName'))]",
                      "dependsOn": [
                        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('mutateIdentityName'))]"
                      ],
                      "properties": {
                        "issuer":    "https://token.actions.githubusercontent.com",
                        "subject":   "[format('repo:{0}:ref:refs/heads/main', parameters('repoFullName'))]",
                        "audiences": [ "api://AzureADTokenExchange" ]
                      }
                    }
                  ],
                  "outputs": {
                    "auditPrincipalId": {
                      "type": "string",
                      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('auditIdentityName')), '2023-01-31').principalId]"
                    },
                    "auditClientId": {
                      "type": "string",
                      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('auditIdentityName')), '2023-01-31').clientId]"
                    },
                    "mutatePrincipalId": {
                      "type": "string",
                      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('mutateIdentityName')), '2023-01-31').principalId]"
                    },
                    "mutateClientId": {
                      "type": "string",
                      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('mutateIdentityName')), '2023-01-31').clientId]"
                    }
                  }
                }
              }
            }
          ],
          "outputs": {
            "auditPrincipalId":  { "type": "string", "value": "[reference('uami-rg-deployment').outputs.auditPrincipalId.value]" },
            "auditClientId":     { "type": "string", "value": "[reference('uami-rg-deployment').outputs.auditClientId.value]" },
            "mutatePrincipalId": { "type": "string", "value": "[reference('uami-rg-deployment').outputs.mutatePrincipalId.value]" },
            "mutateClientId":    { "type": "string", "value": "[reference('uami-rg-deployment').outputs.mutateClientId.value]" }
          }
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(managementGroup().id, parameters('auditIdentityName'), 'reader')]",
      "dependsOn": [ "uami-subscription-deployment" ],
      "properties": {
        "roleDefinitionId": "[tenantResourceId('Microsoft.Authorization/roleDefinitions', variables('readerRoleId'))]",
        "principalId":      "[reference('uami-subscription-deployment').outputs.auditPrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(managementGroup().id, parameters('auditIdentityName'), 'security-reader')]",
      "dependsOn": [ "uami-subscription-deployment" ],
      "properties": {
        "roleDefinitionId": "[tenantResourceId('Microsoft.Authorization/roleDefinitions', variables('securityReaderRoleId'))]",
        "principalId":      "[reference('uami-subscription-deployment').outputs.auditPrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(managementGroup().id, parameters('mutateIdentityName'), 'reader')]",
      "dependsOn": [ "uami-subscription-deployment" ],
      "properties": {
        "roleDefinitionId": "[tenantResourceId('Microsoft.Authorization/roleDefinitions', variables('readerRoleId'))]",
        "principalId":      "[reference('uami-subscription-deployment').outputs.mutatePrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(managementGroup().id, parameters('mutateIdentityName'), 'security-reader')]",
      "dependsOn": [ "uami-subscription-deployment" ],
      "properties": {
        "roleDefinitionId": "[tenantResourceId('Microsoft.Authorization/roleDefinitions', variables('securityReaderRoleId'))]",
        "principalId":      "[reference('uami-subscription-deployment').outputs.mutatePrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(managementGroup().id, parameters('mutateIdentityName'), 'vm-contributor')]",
      "dependsOn": [ "uami-subscription-deployment" ],
      "properties": {
        "roleDefinitionId": "[tenantResourceId('Microsoft.Authorization/roleDefinitions', variables('vmContributorRoleId'))]",
        "principalId":      "[reference('uami-subscription-deployment').outputs.mutatePrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(managementGroup().id, parameters('mutateIdentityName'), 'network-contributor')]",
      "dependsOn": [ "uami-subscription-deployment" ],
      "properties": {
        "roleDefinitionId": "[tenantResourceId('Microsoft.Authorization/roleDefinitions', variables('networkContributorRoleId'))]",
        "principalId":      "[reference('uami-subscription-deployment').outputs.mutatePrincipalId.value]",
        "principalType":    "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "tenantId":           { "type": "string", "value": "[tenant().tenantId]" },
    "managementGroupId":  { "type": "string", "value": "[managementGroup().name]" },
    "hostSubscriptionId": { "type": "string", "value": "[parameters('hostSubscriptionId')]" },
    "clientId":           { "type": "string", "value": "[reference('uami-subscription-deployment').outputs.auditClientId.value]" },
    "mutateClientId":     { "type": "string", "value": "[reference('uami-subscription-deployment').outputs.mutateClientId.value]" }
  }
}
