{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_description": "StackQL audit — read-only OIDC bootstrap for Azure. Creates a User Assigned Managed Identity (UAMI) with a federated identity credential trusted by GitHub Actions, and assigns Reader + Security Reader at subscription scope. No client secrets. Subscription-scope template — Deploy to Azure URL must use the subscription deployment blade."
  },
  "parameters": {
    "repoFullName": {
      "type": "string",
      "metadata": { "description": "GitHub repo allowed to assume this identity (owner/repo)." }
    },
    "subjectPattern": {
      "type": "string",
      "defaultValue": "*",
      "metadata": { "description": "OIDC subject pattern. '*' matches all events (branches, tags, pull_request). Tighten if you want e.g. ref:refs/heads/main only — note federated credentials don't support wildcards natively, see deployment note below." }
    },
    "identityName": {
      "type": "string",
      "defaultValue": "stackql-audit",
      "metadata": { "description": "Name of the UAMI." }
    },
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "stackql-audit-rg",
      "metadata": { "description": "Resource group to create/use for the UAMI." }
    },
    "location": {
      "type": "string",
      "defaultValue": "eastus",
      "metadata": { "description": "Region for the resource group + UAMI. UAMI scope is global; this is the resource metadata location." }
    }
  },
  "variables": {
    "readerRoleId":         "acdd72a7-3385-48ef-bd42-f606fba81ae7",
    "securityReaderRoleId": "39bc4728-0917-49c7-9d2c-d95423bc2eb4"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2022-09-01",
      "name": "[parameters('resourceGroupName')]",
      "location": "[parameters('location')]",
      "properties": {}
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "uami-deployment",
      "resourceGroup": "[parameters('resourceGroupName')]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/resourceGroups', parameters('resourceGroupName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": { "scope": "inner" },
        "parameters": {
          "identityName":   { "value": "[parameters('identityName')]" },
          "location":       { "value": "[parameters('location')]" },
          "repoFullName":   { "value": "[parameters('repoFullName')]" },
          "subjectPattern": { "value": "[parameters('subjectPattern')]" }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "identityName":   { "type": "string" },
            "location":       { "type": "string" },
            "repoFullName":   { "type": "string" },
            "subjectPattern": { "type": "string" }
          },
          "resources": [
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
              "apiVersion": "2023-01-31",
              "name": "[parameters('identityName')]",
              "location": "[parameters('location')]"
            },
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
              "apiVersion": "2023-01-31",
              "name": "[format('{0}/github-actions', parameters('identityName'))]",
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('identityName'))]"
              ],
              "properties": {
                "issuer":    "https://token.actions.githubusercontent.com",
                "subject":   "[format('repo:{0}:{1}', parameters('repoFullName'), parameters('subjectPattern'))]",
                "audiences": [ "api://AzureADTokenExchange" ]
              }
            }
          ],
          "outputs": {
            "principalId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('identityName')), '2023-01-31').principalId]"
            },
            "clientId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('identityName')), '2023-01-31').clientId]"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, parameters('identityName'), 'reader')]",
      "dependsOn": [ "uami-deployment" ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('readerRoleId'))]",
        "principalId":      "[reference('uami-deployment').outputs.principalId.value]",
        "principalType":    "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, parameters('identityName'), 'security-reader')]",
      "dependsOn": [ "uami-deployment" ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('securityReaderRoleId'))]",
        "principalId":      "[reference('uami-deployment').outputs.principalId.value]",
        "principalType":    "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "tenantId": {
      "type": "string",
      "value": "[subscription().tenantId]"
    },
    "subscriptionId": {
      "type": "string",
      "value": "[subscription().subscriptionId]"
    },
    "clientId": {
      "type": "string",
      "value": "[reference('uami-deployment').outputs.clientId.value]"
    }
  }
}
